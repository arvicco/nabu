	  <div type="sūkta" n="003">
	    <lg xml:id="RV_1.003.01">
	      <l n="1.003.01a">aśvi<orig>̍</orig>nā<orig>̱</orig> yajva<orig>̍</orig>rī<orig>̱</orig>r iṣo<orig>̱</orig> drava<orig>̍</orig>tpāṇī<orig>̱</orig> śubha<orig>̍</orig>s patī |</l>
