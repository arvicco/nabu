	      <l n="1.001.03c">ya<orig>̱</orig>śasa<orig>̍</orig>ṁ vī<orig>̱</orig>rava<orig>̍</orig>ttamam ||</l>
	    </lg>
	    <lg xml:id="RV_1.001.04">
	      <l n="1.001.04a">agne<orig>̱</orig> yaṁ ya<orig>̱</orig>jñam a<orig>̍</orig>dhva<orig>̱</orig>raṁ vi<orig>̱</orig>śvata<orig>̍</orig>ḥ pari<orig>̱</orig>bhūr asi<orig>̍</orig> |</l>
	      <l n="1.001.04c">sa id de<orig>̱</orig>veṣu<orig>̍</orig> gacchati ||</l>
	    </lg>
	    <lg xml:id="RV_1.001.05">
	      <l n="1.001.05a">a<orig>̱</orig>gnir hotā<orig>̍</orig> ka<orig>̱</orig>vikra<orig>̍</orig>tuḥ sa<orig>̱</orig>tyaś ci<orig>̱</orig>traśra<orig>̍</orig>vastamaḥ |</l>
	      <l n="1.001.05c">de<orig>̱</orig>vo de<orig>̱</orig>vebhi<orig>̱</orig>r ā ga<orig>̍</orig>mat ||</l>
	    </lg>
	    <lg xml:id="RV_1.001.06">
	      <l n="1.001.06a">yad a<orig>̱</orig>ṅga dā<orig>̱</orig>śuṣe<orig>̱</orig> tvam agne<orig>̍</orig> bha<orig>̱</orig>draṁ ka<orig>̍</orig>ri<orig>̱</orig>ṣyasi<orig>̍</orig> |</l>
	      <l n="1.001.06c">tavet tat sa<orig>̱</orig>tyam a<orig>̍</orig>ṅgiraḥ ||</l>
	    </lg>
	    <lg xml:id="RV_1.001.07">
