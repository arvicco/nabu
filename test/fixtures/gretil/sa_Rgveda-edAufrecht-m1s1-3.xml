	    </lg>

	  </div>
	  <div type="sūkta" n="002">
	    <lg xml:id="RV_1.002.01">
	      <l n="1.002.01a">vāya<orig>̱</orig>v ā yā<orig>̍</orig>hi darśate<orig>̱</orig>me somā<orig>̱</orig> ara<orig>̍</orig>ṁkṛtāḥ |</l>
