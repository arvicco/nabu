	      <l n="1.001.07c">namo<orig>̱</orig> bhara<orig>̍</orig>nta<orig>̱</orig> ema<orig>̍</orig>si ||</l>
	    </lg>
	    <lg xml:id="RV_1.001.08">
	      <l n="1.001.08a">rāja<orig>̍</orig>ntam adhva<orig>̱</orig>rāṇā<orig>̍</orig>ṁ go<orig>̱</orig>pām ṛ<orig>̱</orig>tasya<orig>̱</orig> dīdi<orig>̍</orig>vim |</l>
