liv_base:Lexicon a crm:E31, lime:Lexicon;
  dct:contributor "Valeria Boano, Marco Passarotti, Francesco Mambrini, Riccardo Ginevra, Giovanni Moretti";
  dct:creator "Helmut Rix, Martin Kümmel, Thomas Zehnder, Reiner Lipp, Brigitte Schirmer";
  dct:description "The Lexicon Der Indogermanischen Verben is an etymological dictionary of proto-indo-european verbal roots and stems, which aims to collect them together systematically and to make possible to follow their development in single indo-european languages. The version published in LiLa is the second edition published in 2001.";
